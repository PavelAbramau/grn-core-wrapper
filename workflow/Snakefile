    shell:
        """
        scenicplus grn_inference AUCell \
            --eRegulon_fname {input.eRegulons_extended} \
            --multiome_mudata_fname {input.multiome_mudata_fname} \
            --aucell_out_fname {output.aucell_extended_out_fname} \
            --n_cpu {threads}
        """
